# HTTP
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# gRPC
GRPC_ADDR=:9090

# API-key auth (optional; disabled unless API_KEYS is set). When set, uploads
# and deletes require `Authorization: Bearer <key>`. Downloads stay open.
# API_KEYS=dev-key-1,dev-key-2         # comma-separated

# Signed download links (optional; disabled unless DOWNLOAD_SIGNING_KEY is set).
# When set, download URLs carry an expiring HMAC signature so they can't be
# forged or reused past DOWNLOAD_URL_TTL.
# DOWNLOAD_SIGNING_KEY=change-me
DOWNLOAD_URL_TTL=1h

# Distributed tracing (optional; disabled unless an OTLP endpoint is set).
# Standard OpenTelemetry env vars are honored. Point at the bundled Jaeger:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_SERVICE_NAME=dropcrate

# Kafka domain events (optional; disabled unless KAFKA_BROKERS is set)
# KAFKA_BROKERS=127.0.0.1:9092        # comma-separated broker list
KAFKA_TOPIC_PREFIX=dropcrate.         # topic = prefix + event type, e.g. dropcrate.file.uploaded
MAX_UPLOAD_BYTES=104857600   # 100 MiB
DEFAULT_TTL=168h             # 7 days; used when an upload omits a ttl

# Expired-file reaper (runs in-process during `serve`)
SWEEP_INTERVAL=15m           # how often to reap expired files; <=0 disables
SWEEP_BATCH=100              # max files deleted per query

# MySQL
MYSQL_DSN=app:secret@tcp(127.0.0.1:3306)/app?parseTime=true&multiStatements=true

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 / MinIO
S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=guest
S3_SECRET_KEY=supersecret
S3_BUCKET=dropcrate
S3_REGION=us-east-1
S3_USE_SSL=false
